{
  "id": "lintropy",
  "name": "Lintropy",
  "programArgs": {
    "default": "lintropy lsp"
  },
  "fileTypeMappings": [
    {
      "fileType": {
        "name": "Rust",
        "patterns": ["*.rs"]
      },
      "languageId": "rust"
    },
    {
      "fileType": {
        "name": "Lintropy YAML",
        "patterns": ["lintropy.yaml", "*.rule.yaml", "*.rules.yaml"]
      },
      "languageId": "yaml"
    }
  ]
}
